# -----------------------------------------------------------------------------
# Mentor::i Environment Configuration
#
# Copy this file to .env and customize for your environment.
# This file defines environment-specific variables for running the Mentor::i
# application services. User-specific settings like API keys and model IDs
# are configured in the application's UI.
# -----------------------------------------------------------------------------

# --- Networking & CORS ---
# The full URL of the frontend application. This is critical for the backend
# to set the correct CORS headers, allowing the browser to connect.
# In a production environment, this should be the public URL of the app.
FRONTEND_URL=https://localhost:5173

OLLAMA_BASE_URL="http://localhost:11434"


# SSL/TLS Configuration for HTTPS
SSL_CERT_PATH=/app/localhost.pem
SSL_KEY_PATH=/app/localhost-key.pem


# --- Server Configuration ---
# The IP address the backend servers will bind to.
# 0.0.0.0 makes it accessible from other machines on the network.
BACKEND_HOST=0.0.0.0

# The port for the main WebSocket server.
BACKEND_PORT=8765

# The port for the HTTP API server (handles auth, tasks, etc.).
FILE_SERVER_PORT=8766

# --- Diagnostics ---
# The logging level for the backend services.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Docker Compose ---
# For server-specific settings (like custom IP), copy docker-compose.override.yml.example
# to docker-compose.override.yml and customize there.
